&lt;h2&gt;Images&lt;/h2&gt;
&lt;p&gt;
        &lt;/p&gt;&lt;figure&gt;
          &lt;picture&gt;&lt;source type=&quot;image/webp&quot; srcset=&quot;https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/Umn9MXSo0W-400.webp 400w, https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/Umn9MXSo0W-800.webp 800w, https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/Umn9MXSo0W-896.webp 896w&quot; sizes=&quot;100vw&quot;&gt;&lt;img loading=&quot;lazy&quot; decoding=&quot;async&quot; src=&quot;https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/Umn9MXSo0W-400.jpeg&quot; alt=&quot;Minion&quot; width=&quot;896&quot; height=&quot;896&quot; srcset=&quot;https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/Umn9MXSo0W-400.jpeg 400w, https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/Umn9MXSo0W-800.jpeg 800w, https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/Umn9MXSo0W-896.jpeg 896w&quot; sizes=&quot;100vw&quot;&gt;&lt;/picture&gt;
          &lt;figcaption&gt;Minion&lt;/figcaption&gt;
