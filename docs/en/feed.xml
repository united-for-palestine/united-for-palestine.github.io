        &lt;figure&gt;
          &lt;picture&gt;&lt;source type=&quot;image/webp&quot; srcset=&quot;https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/fVHjIqNB3G-400.webp 400w, https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/fVHjIqNB3G-704.webp 704w&quot; sizes=&quot;100vw&quot;&gt;&lt;img loading=&quot;lazy&quot; decoding=&quot;async&quot; src=&quot;https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/fVHjIqNB3G-400.jpeg&quot; alt=&quot;Stormtroopocat&quot; width=&quot;704&quot; height=&quot;676&quot; srcset=&quot;https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/fVHjIqNB3G-400.jpeg 400w, https://united-for-palestine.github.io/en/post/cyprus_a_rest_stop_and_propaganda_tool_for_the_idf/fVHjIqNB3G-704.jpeg 704w&quot; sizes=&quot;100vw&quot;&gt;&lt;/picture&gt;
